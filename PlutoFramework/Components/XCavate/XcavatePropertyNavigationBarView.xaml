<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:xcavate="clr-namespace:PlutoFramework.Components.Xcavate"
             x:Class="PlutoFramework.Components.Xcavate.XcavatePropertyNavigationBarView"
             AbsoluteLayout.LayoutBounds="0.5, 1, 1, 90"
             AbsoluteLayout.LayoutFlags="PositionProportional, WidthProportional">

    <xcavate:PageBottomBarView>

        <xcavate:PageBottomBarView.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </xcavate:PageBottomBarView.ColumnDefinitions>


        <xcavate:XcavatePropertyNavigationBarButtonView
            Grid.Column="0"
            Title="Details"
            IconUnselected="xcavatedetailsunselected.png"
            IconSelected="xcavatedetailsselected.png"
            IsSelected="{Binding DetailsIsSelected}"
            Command="{Binding SelectDetailsCommand}"
        >
        </xcavate:XcavatePropertyNavigationBarButtonView>

        <xcavate:XcavatePropertyNavigationBarButtonView
            Grid.Column="1"
            Title="Messages"
            IconUnselected="xcavatemessagesunselected.png"
            IconSelected="xcavatemessagesselected.png"
            IsSelected="{Binding MessagesIsSelected}"
            Command="{Binding SelectMessagesCommand}"
        >
        </xcavate:XcavatePropertyNavigationBarButtonView>
        
        <xcavate:XcavatePropertyNavigationBarButtonView
            Grid.Column="2"
            Title="Documents"
            IconUnselected="xcavatedocumentsunselected.png"
            IconSelected="xcavatedocumentsselected.png"
            IsSelected="{Binding DocumentsIsSelected}"
            Command="{Binding SelectDocumentsCommand}"
        >
        </xcavate:XcavatePropertyNavigationBarButtonView>
        
        <xcavate:XcavatePropertyNavigationBarButtonView
            Grid.Column="3"
            Title="Actions"
            IconUnselected="xcavateactionsunselected.png"
            IconSelected="xcavateactionsselected.png"
            IsSelected="{Binding ActionsIsSelected}"
            Command="{Binding SelectActionsCommand}"
        >
        </xcavate:XcavatePropertyNavigationBarButtonView>
    </xcavate:PageBottomBarView>
</ContentView>